<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!--
        Production profile: emit structured JSON to stdout only.
        Container/orchestrator (Docker, K8s) is responsible for log shipping.
    -->
    <springProfile name="prod">
        <appender name="JSON_STDOUT" class="ch.qos.logback.core.ConsoleAppender">
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <includeMdcKeyName>traceId</includeMdcKeyName>
                <includeMdcKeyName>spanId</includeMdcKeyName>
                <includeMdcKeyName>userId</includeMdcKeyName>
                <includeMdcKeyName>requestId</includeMdcKeyName>
                <customFields>{"app":"gembud-backend"}</customFields>
            </encoder>
        </appender>

        <root level="INFO">
            <appender-ref ref="JSON_STDOUT"/>
        </root>

        <logger name="com.gembud" level="INFO"/>
        <logger name="org.springframework.security" level="INFO"/>
    </springProfile>

    <!--
        Dev / test / default profiles: keep human-readable plain text on stdout.
    -->
    <springProfile name="dev,test,default">
        <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>

        <logger name="com.gembud" level="DEBUG"/>
    </springProfile>
</configuration>
