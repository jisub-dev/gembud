# =================================
# Gembud Environment Variables
# =================================

# Database
DATABASE_NAME=gembud
DATABASE_USERNAME=gembud_user
DATABASE_PASSWORD=your_secure_database_password_here
DATABASE_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your_secure_redis_password_here

# JWT
JWT_SECRET=your-jwt-secret-key-at-least-256-bits-long-change-this-in-production

# OAuth2 - Google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth2 - Discord
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Server Ports
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Frontend Environment (for build)
VITE_API_BASE_URL=http://localhost:8080/api
VITE_WS_BASE_URL=ws://localhost:8080/ws

# Reverse Proxy / TLS (Caddy)
DOMAIN=gembud.example.com
ACME_EMAIL=admin@example.com

# Sentry (optional — leave empty to disable error tracking)
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=

VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=
